# Ember — Environment Variables
# Copy this file to .env.local and fill in your values.
# Without these, Ember runs in pure local mode (no sync).

# Supabase project URL (from supabase.com dashboard → Settings → API)
VITE_SUPABASE_URL=

# Supabase anonymous/public key (from same Settings → API page)
VITE_SUPABASE_ANON_KEY=

# Gemini API key (from Google AI Studio → API Keys)
# Enables AI-powered tutor responses and image generation.
VITE_GEMINI_API_KEY=
