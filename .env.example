# Ember — Environment Variables
# Copy this file to .env.local and fill in your values.
# Without these, Ember runs in pure local mode (no sync).

# Supabase project URL (from supabase.com dashboard → Settings → API)
VITE_SUPABASE_URL=

# Supabase anonymous/public key (from same Settings → API page)
VITE_SUPABASE_ANON_KEY=

# Gemini API key — two modes:
#
# 1. Local development: set VITE_GEMINI_API_KEY here.
#    The key is bundled client-side (fine for local dev, not for production).
VITE_GEMINI_API_KEY=
#
# 2. Production (Vercel): set GEMINI_API_KEY in Vercel Environment Variables.
#    The key stays server-side in Edge Functions (/api/gemini-*).
#    Do NOT set VITE_GEMINI_API_KEY in production.
GEMINI_API_KEY=
